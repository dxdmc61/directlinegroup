{
  "templates": [
    {
      "name": "azure-explore",
      "urls": [
        "https://azure.microsoft.com/en-us/explore/"
      ],
      "description": "Azure Explore landing page with hero, product categories, customer stories, and call-to-action sections",
      "blocks": [
        {
          "name": "hero-azure",
          "selector": ".section-master--blade-hero-slim",
          "parser": "parsers/hero-azure.js",
          "description": "Hero with gradient background, heading, description, CTAs"
        },
        {
          "name": "cards-feature",
          "selector": ".three-up-cards, .block-feature",
          "parser": "parsers/cards-feature.js",
          "description": "Feature cards (image + heading + description)"
        },
        {
          "name": "columns-metrics",
          "selector": ".card-grid--disable-card-promo",
          "parser": "parsers/columns-metrics.js",
          "description": "Statistics/metrics section with case study and stat cards"
        },
        {
          "name": "accordion-faq",
          "selector": ".ocr-faq",
          "parser": "parsers/accordion-faq.js",
          "description": "FAQ accordion with numbered items"
        },
        {
          "name": "cards-customer",
          "selector": ".carousel--type-case-study",
          "parser": "parsers/cards-customer.js",
          "description": "Customer story cards carousel"
        }
      ]
    }
  ]
}
